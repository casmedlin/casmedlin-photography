---
import Layout from '../layouts/Layout.astro';

const photos = [
  { src: '/astrophotography/2025-05-22_03-30-35_454.webp', alt: 'Astrophotography photo' },
  { src: '/astrophotography/23-08-14 23-09-40 0690.webp', alt: 'Astrophotography photo' },
  { src: '/astrophotography/294518D8-40EC-4C93-B49D-5A4BF14A0BD5DSC00146b.webp', alt: 'Astrophotography photo' },
  { src: '/astrophotography/2A5F4959-4464-4343-B76B-69D393E8F9D12024-08-10_21-26-04_924.webp', alt: 'Astrophotography photo' },
  { src: '/astrophotography/DSC03667.webp', alt: 'Astrophotography photo' },
];
---

<Layout title="Astrophotography" description="Stunning astrophotography showcasing the night sky, Milky Way, aurora, and celestial events. Night sky photography by Cas Medlin in North Carolina.">
  <div class="gallery">
    {photos.map((photo) => (
      <a href={photo.src} class="gallery-item">
        <img src={photo.src} alt={photo.alt} loading="lazy" />
      </a>
    ))}
  </div>
</Layout>

<style>
  .gallery {
    max-width: 1800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .gallery-item {
    display: block;
    overflow: hidden;
  }
  .gallery-item img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    transition: transform 0.5s;
  }
  .gallery-item:hover img {
    transform: scale(1.05);
  }
</style>
