---
import Layout from '../layouts/Layout.astro';
import dimensions from '../data/image-dimensions.json';

function getDims(src) {
  const cleanSrc = src.startsWith('/') ? src.slice(1) : src;
  const parts = cleanSrc.split('/');
  const file = parts.pop();
  const folder = parts[parts.length - 1] || 'root';
  return dimensions[folder]?.[file] || { width: 800, height: 600 };
}

const photos = [
  { src: '/astrophotography/2025-05-22_03-30-35_454.webp', alt: 'Milky Way over Cape Lookout, North Carolina by Cas Medlin' },
  { src: '/astrophotography/23-08-14 23-09-40 0690.webp', alt: 'Star over Yurt in Maine by Cas Medlin' },
  { src: '/astrophotography/294518D8-40EC-4C93-B49D-5A4BF14A0BD5DSC00146b.webp', alt: 'Red and Green Aurora borealis over Iredell County, NC by Cas Medlin' },
  { src: '/astrophotography/2A5F4959-4464-4343-B76B-69D393E8F9D12024-08-10_21-26-04_924.webp', alt: 'Milky Way over Shenandoah National Park by Cas Medlin' },
  { src: '/astrophotography/DSC03667.webp', alt: 'Pink Aurora borealis over Iredell County, NC by Cas Medlin' },
  { src: '/astrophotography/02D171D5-53B9-4A93-933B-8C2A38049169.webp', alt: 'Star trails over the Blue Ridge Mountains by Cas Medlin' },
  { src: '/astrophotography/StarStaX_DSC03647b-DSC03706_lighten.webp', alt: 'Star trails Pink Aurora borealis over Iredell County, NC by Cas Medlin' },
  { src: '/astrophotography/2024-08-31_21-26-16_900.webp', alt: 'Milky Way over OBX, NC by Cas Medlin' },
];
---

<Layout title="Astrophotography | Cas Medlin | Night Sky Photography NC" description="Stunning astrophotography showcasing the night sky, Milky Way, aurora, and celestial events. Night sky photography by Cas Medlin in North Carolina." breadcrumbs={[{ name: 'Astrophotography', url: '/astrophotography' }]}>
  <h1 class="page-title">Astrophotography</h1>
  <div class="gallery">
    {photos.map((photo, i) => {
      const dims = getDims(photo.src);
      return (
        <a href={photo.src} class="gallery-item">
          <img src={photo.src} alt={photo.alt} width={dims.width} height={dims.height} loading={i < 2 ? "eager" : "lazy"} fetchpriority={i < 2 ? "high" : "auto"} />
        </a>
      );
    })}
  </div>
</Layout>

<style>
  .page-title {
    font-size: 0.875rem;
    font-weight: 400;
    color: #fff;
    margin: 1rem 0 1.5rem;
    padding-left: 0.5rem;
    letter-spacing: 0.05em;
  }
  .gallery {
    max-width: 1800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    padding: 0 0.5rem;
  }
  @media (min-width: 768px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .gallery-item {
    display: block;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid #2a2a2a;
    transition: border-color 0.3s, transform 0.3s;
  }
  .gallery-item:hover {
    border-color: #404040;
    transform: translateY(-2px);
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s;
  }
  .gallery-item:hover img {
    transform: scale(1.05);
  }
</style>
