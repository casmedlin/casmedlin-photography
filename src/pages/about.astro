---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Meet Cas Medlin - freelance photographer and graphic designer based in Iredell County, North Carolina. Christian, creative, and passionate about capturing life's moments." image="/DSC06596.webp">
  <div class="content">
    <div class="hero">
      <div class="hero-image">
        <img src="/DSC06596.webp" alt="Cas Medlin" />
      </div>
      <div class="hero-text">
        <h1>Hi, I'm Cas</h1>
        <p class="subtitle">Freelance Photographer & Graphic Designer</p>
      </div>
    </div>

    <div class="about-grid">
      <div class="about-text">
        <p>Based in Iredell County, North Carolina, serving the greater Charlotte area including Mooresville, Troutman, and Statesville.</p>
        <p>I'm a passionate Christian, photographer, and graphic designer dedicated to capturing life's meaningful moments. Whether it's the perfect landscape, a cherished pet, or a milestone event, I bring creativity and care to every session.</p>
        <p>Check out my other project at <a href="https://www.biblicalencouragement.org/" target="_blank" rel="noopener">Biblical Encouragement</a> for biblically rooted encouragement.</p>
        <p>I currently serve as photographer and digital media coordinator for <a href="https://faithstatesville.org/" target="_blank" rel="noopener">Faith Church Statesville</a>.</p>
      </div>

      <div class="contact-section">
        <div class="contact-card">
          <h2>Let's Work Together</h2>
          <p>Have a project in mind or want to book a session?</p>
          <a href="mailto:info@casmedlin.com" class="email-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            info@casmedlin.com
          </a>
        </div>

        <div class="services">
          <h3>Specialties</h3>
          <ul>
            <li><a href="/landscapes">Landscape Photography</a></li>
            <li><a href="/wildlife">Wildlife & Nature</a></li>
            <li><a href="/portraits">Portrait Sessions</a></li>
            <li><a href="/events">Event Coverage</a></li>
            <li><a href="/pets">Pet Photography</a></li>
            <li><a href="/astrophotography">Astrophotography</a></li>
            <li><a href="/architecture">Architecture</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .hero {
    display: flex;
    gap: 3rem;
    align-items: center;
    margin-bottom: 4rem;
  }
  .hero-image {
    flex: 1;
    max-width: 400px;
  }
  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
  }
  .hero-text h1 {
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .subtitle {
    font-size: 1.25rem;
    color: #a3a3a3;
    font-weight: 300;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .about-text p {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #a3a3a3;
    margin-bottom: 1.5rem;
  }
  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .contact-card {
    padding: 2rem;
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.02);
  }
  .contact-card h2 {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }
  .contact-card p {
    font-size: 1rem;
    color: #a3a3a3;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .email-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: #7ccf3c;
    color: #fff;
    text-decoration: none;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.2s, transform 0.2s;
  }
  .email-btn:hover {
    background: #6bb12f;
    transform: translateY(-1px);
  }
  .about-text a {
    color: #7ccf3c;
  }
  .about-text a:hover,
  .about-text a:focus {
    color: #9de667;
  }
  .email-btn {
    color: #fff;
  }
  .email-btn:hover,
  .email-btn:focus {
    color: #fff;
  }
  .services h3 {
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: 1rem;
    color: #e5e5e5;
  }
  .services ul {
    list-style: none;
    padding: 0;
  }
  .services li {
    padding: 0.5rem 0;
    color: #a3a3a3;
    font-size: 1rem;
    border-bottom: 1px solid #1a1a1a;
  }
  .services li:last-child {
    border-bottom: none;
  }
  .services li a {
    color: #7ccf3c;
    text-decoration: none;
    display: inline-block;
    width: 100%;
  }
  .services li a:hover,
  .services li a:focus {
    color: #9de667;
    text-decoration: none;
  }
  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }
    .hero-image {
      flex: none;
      width: 250px;
      margin: 0 auto;
    }
    .hero-text h1 {
      font-size: 2.5rem;
    }
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>