---
import Layout from '../layouts/Layout.astro';
import dimensions from '../data/image-dimensions.json';

function getDims(src) {
  const cleanSrc = src.startsWith('/') ? src.slice(1) : src;
  const parts = cleanSrc.split('/');
  const file = parts.pop();
  const folder = parts[parts.length - 1] || 'root';
  return dimensions[folder]?.[file] || { width: 800, height: 600 };
}

const photos = [
  { src: '/Architecture/23-08-13 10-50-37 0722.webp', alt: 'Architecture photo 23-08-13 10-50-37 0722' },
  { src: '/Architecture/DSC00323.webp', alt: 'Architecture photo DSC00323' },
  { src: '/Architecture/DSC03332.webp', alt: 'Architecture photo DSC03332' },
  { src: '/Architecture/DSC04725 Large.webp', alt: 'Architecture photo DSC04725 Large' },
  { src: '/hCydvjybRh-HUghO949Ufw.webp', alt: 'Architecture photo hCydvjybRh-HUghO949Ufw' },
  { src: '/Architecture/DSC02456.webp', alt: 'Architecture photo' },
  { src: '/Architecture/DSC08754 3.webp', alt: 'Architecture photo' },
  { src: '/Architecture/July 22 CAS_0984(1).webp', alt: 'Architecture photo' }
];
---

<Layout title="Architecture Photography" description="Architecture photography by Cas Medlin showcasing structures, geometry, and urban form from across the region.">
  <div class="gallery">
    {photos.map((photo, i) => {
      const dims = getDims(photo.src);
      return (
        <a href={photo.src} class="gallery-item">
          <img src={photo.src} alt={photo.alt} width={dims.width} height={dims.height} loading={i < 2 ? "eager" : "lazy"} fetchpriority={i < 2 ? "high" : "auto"} />
        </a>
      );
    })}
  </div>
</Layout>

<style>
  .gallery {
    max-width: 1800px;
    margin: 0 auto;
    columns: 2;
    column-gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .gallery { columns: 3; }
  }
  @media (min-width: 1024px) {
    .gallery { columns: 4; }
  }
  .gallery-item { display: block; break-inside: avoid; margin-bottom: 0.5rem; }
  .gallery-item img { width: 100%; height: auto; display: block; transition: transform 0.5s; }
  .gallery-item:hover img { transform: scale(1.02); }
</style>
