---
import Layout from '../layouts/Layout.astro';

let photos = [
  { src: '/pets/2023-12-04_17-13-23_621.webp', alt: 'Pet photo 2023-12-04', ratio: 0.6666 },
  { src: '/pets/2023-12-04_16-52-14_336 (2023-12-17T13_14_31.240).webp', alt: 'Pet photo 2023-12-04', ratio: 0.6667 },
  { src: '/pets/DSC01004.webp', alt: 'Pet photo DSC01004', ratio: 0.6667 },
  { src: '/pets/DSC02058.webp', alt: 'Pet photo DSC02058', ratio: 0.6667 },
  { src: '/pets/DSC02123.webp', alt: 'Pet photo DSC02123', ratio: 0.6667 },
  { src: '/pets/DSC04153.webp', alt: 'Pet photo DSC04153', ratio: 0.6667 },
  { src: '/pets/DSC09913.webp', alt: 'Pet photo DSC09913', ratio: 0.6667 },
  { src: '/pets/DSC03490.webp', alt: 'Pet photo DSC03490', ratio: 0.971 },
  { src: '/pets/DSC09920.webp', alt: 'Pet photo DSC09920', ratio: 1.0561 },
  { src: '/pets/DSC04995.webp', alt: 'Pet photo DSC04995', ratio: 1.431 },
  { src: '/pets/20200417_150802.webp', alt: 'Pet photo 2020-04-17', ratio: 1.5 },
  { src: '/pets/Aug 2022CAS_0233.webp', alt: 'Pet photo Aug 2022 CAS 0233', ratio: 1.5 },
  { src: '/pets/CAS_0015.webp', alt: 'Pet photo CAS 0015', ratio: 1.5 },
  { src: '/pets/DSC04992.webp', alt: 'Pet photo DSC04992', ratio: 1.4988 },
  { src: '/pets/July - Aug 2022CAS_0825.webp', alt: 'Pet photo July-Aug 2022 CAS 0825', ratio: 1.5006 },
  { src: '/pets/DSC02122 2.webp', alt: 'Pet photo DSC02122 2', ratio: 1.7483 },
];
  // Group by orientation and alternate portrait and landscape images
  photos.sort((a, b) => a.ratio - b.ratio);
  const portrait = photos.filter((p) => p.ratio < 1);
  const landscape = photos.filter((p) => p.ratio >= 1);
  const arranged = [];
  let portraitIndex = 0;
  let landscapeIndex = 0;
  while (portraitIndex < portrait.length || landscapeIndex < landscape.length) {
    if (portraitIndex < portrait.length) arranged.push(portrait[portraitIndex++]);
    if (landscapeIndex < landscape.length) arranged.push(landscape[landscapeIndex++]);
  }
  photos = arranged;
---

<Layout title="Pet Photography" description="Adorable pet photography sessions capturing your furry friends' personality. Dog, cat, and pet portraits in Iredell County, NC by Cas Medlin.">
  <div class="gallery">
    {photos.map((photo, i) => (
      <a href={photo.src} class={`gallery-item ${photo.ratio > 1.2 ? 'wide' : ''} ${i < 2 ? 'featured' : ''}`}>
        <img src={photo.src} alt={photo.alt} loading="lazy" />
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    max-width: 1800px;
    margin: 0 auto 2rem;
    padding: 0 0.5rem;
  }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
  }
  .page-header p {
    color: #a3a3a3;
    font-size: 1rem;
  }
  .gallery {
    max-width: 1800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    padding: 0 0.5rem;
  }
  @media (min-width: 768px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
    .gallery-item.wide {
      grid-column: span 2;
    }
    .gallery-item.featured {
      grid-column: span 1;
    }
    .gallery-item.featured:first-child {
      grid-column: span 2;
      grid-row: span 2;
    }
  }
  @media (min-width: 1024px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .gallery-item {
    display: block;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid #2a2a2a;
    transition: border-color 0.3s;
  }
  .gallery-item:hover {
    border-color: #404040;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s;
  }
  .gallery-item:hover img {
    transform: scale(1.05);
  }
</style>
