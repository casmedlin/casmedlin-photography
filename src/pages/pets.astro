---
import Layout from '../layouts/Layout.astro';
import dimensions from '../data/image-dimensions.json';

function getDims(src) {
  const cleanSrc = src.startsWith('/') ? src.slice(1) : src;
  const parts = cleanSrc.split('/');
  const file = parts.pop();
  const folder = parts[parts.length - 1] || 'root';
  return dimensions[folder]?.[file] || { width: 800, height: 600 };
}

let photos = [
  { src: '/pets/2023-12-04_17-13-23_621.webp', alt: 'Pet portrait of dog with happy expression', ratio: 0.6666 },
  { src: '/pets/2023-12-04_16-52-14_336 (2023-12-17T13_14_31.240).webp', alt: 'Cat portrait with curious gaze', ratio: 0.6667 },
  { src: '/pets/DSC01004.webp', alt: 'Dog sitting for portrait session', ratio: 0.6667 },
  { src: '/pets/DSC02058.webp', alt: 'Pet photo with playful energy', ratio: 0.6667 },
  { src: '/pets/DSC02123.webp', alt: 'Dog portrait in outdoor setting', ratio: 0.6667 },
  { src: '/pets/DSC04153.webp', alt: 'Close-up pet portrait with warm tones', ratio: 0.6667 },
  { src: '/pets/DSC09913.webp', alt: 'Bubby the Cocker Spaniel Chihuahua mix portrait', ratio: 0.6667 },
  { src: '/pets/DSC03490.webp', alt: 'Pet portrait with natural lighting', ratio: 0.471 },
  { src: '/pets/DSC09920.webp', alt: 'Dog resting comfortably during portrait session', ratio: 0.0561 },
  { src: '/pets/DSC04995.webp', alt: 'Cat lounging for portrait session', ratio: 1.431 },
  { src: '/pets/CAS_0015.webp', alt: 'Pet portrait capturing personality', ratio: 1.5 },
  { src: '/pets/DSC04992.webp', alt: 'Dog portrait with expressive eyes', ratio: 1.4988 },
  { src: '/pets/DSC02122 2.webp', alt: 'Pet playing during portrait session', ratio: 1.7483 },
];
  // Group by orientation and alternate portrait and landscape images
  photos.sort((a, b) => a.ratio - b.ratio);
  const portrait = photos.filter((p) => p.ratio < 1);
  const landscape = photos.filter((p) => p.ratio >= 1);
  const arranged = [];
  let portraitIndex = 0;
  let landscapeIndex = 0;
  while (portraitIndex < portrait.length || landscapeIndex < landscape.length) {
    if (portraitIndex < portrait.length) arranged.push(portrait[portraitIndex++]);
    if (landscapeIndex < landscape.length) arranged.push(landscape[landscapeIndex++]);
  }
  photos = arranged;
---

<Layout title="Pet Photography | Cas Medlin | Iredell County, NC" description="Adorable pet photography sessions capturing your furry friends' personality. Dog, cat, and pet portraits in Iredell County, NC by Cas Medlin." breadcrumbs={[{ name: 'Pets', url: '/pets' }]}>
  <h1 class="page-title">Pet Photography</h1>
  <div class="gallery">
    {photos.map((photo, i) => {
      const dims = getDims(photo.src);
      return (
        <a href={photo.src} class={`gallery-item ${photo.ratio > 1.2 ? 'wide' : ''} ${i < 2 ? 'featured' : ''}`}>
          <img src={photo.src} alt={photo.alt} width={dims.width} height={dims.height} loading={i < 2 ? "eager" : "lazy"} fetchpriority={i < 2 ? "high" : "auto"} />
        </a>
      );
    })}
  </div>
</Layout>

<style>
  .page-title {
    font-size: 0.875rem;
    font-weight: 400;
    color: #fff;
    margin: 1rem 0 1.5rem;
    padding-left: 0.5rem;
    letter-spacing: 0.05em;
  }
  .gallery {
    max-width: 1800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    padding: 0 0.5rem;
  }
  @media (min-width: 768px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
    .gallery-item.wide {
      grid-column: span 2;
    }
    .gallery-item.featured {
      grid-column: span 1;
    }
    .gallery-item.featured:first-child {
      grid-column: span 2;
      grid-row: span 2;
    }
  }
  @media (min-width: 1024px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .gallery-item {
    display: block;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid #2a2a2a;
    transition: border-color 0.3s;
  }
  .gallery-item:hover {
    border-color: #404040;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s;
  }
  .gallery-item:hover img {
    transform: scale(1.05);
  }
</style>
