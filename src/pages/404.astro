---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Cas Medlin Photography" description="The page you are looking for does not exist.">
  <div class="error-container">
    <h1>
      <span class="error-code">404</span>
      <span class="error-title">Page Not Found</span>
    </h1>
    <p class="error-message">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="home-link">Go Back Home</a>
    <p class="complaint">Found a broken link? Complain at <a href="mailto:info@casmedlin.com">info@casmedlin.com</a></p>
  </div>
</Layout>

<style>
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: 2rem;
  }
  .error-code {
    font-size: 8rem;
    font-weight: 300;
    color: #22c55e;
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .error-title {
    font-size: 2rem;
    font-weight: 400;
    color: #fff;
    margin-bottom: 1rem;
  }
  .error-message {
    font-size: 1rem;
    color: #a3a3a3;
    margin-bottom: 2rem;
    max-width: 500px;
  }
  .home-link {
    display: inline-block;
    background: #22c55e;
    color: #151515;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.025em;
    transition: background 0.2s;
    margin-bottom: 2rem;
  }
  .home-link:hover {
    background: #16a34a;
  }
  .complaint {
    font-size: 0.875rem;
    color: #a3a3a3;
  }
  .complaint a {
    color: #22c55e;
    text-decoration: none;
    transition: color 0.2s;
  }
  .complaint a:hover {
    color: #16a34a;
  }
  @media (max-width: 768px) {
    .error-code {
      font-size: 6rem;
    }
    .error-title {
      font-size: 1.5rem;
    }
  }
</style>
