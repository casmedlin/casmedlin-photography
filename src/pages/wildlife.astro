---

<Layout title="Wildlife Photography | Cas Medlin | North Carolina Photographer" description="Captivating wildlife photography showcasing animals in their natural habitats. Browse photos of birds, mammals, and nature scenes by Cas Medlin." breadcrumbs={[{ name: 'Wildlife', url: '/wildlife' }]}>
  <h1 class="page-title">Wildlife Photography</h1>
  <div class="gallery">
    {photos.map((photo, i) => {
      const dims = getDims(photo.src);
      return (
        <a href={photo.src} class="gallery-item">
          <img src={photo.src} alt={photo.alt} width={dims.width} height={dims.height} loading={i < 2 ? "eager" : "lazy"} fetchpriority={i < 2 ? "high" : "auto"} />
        </a>
      );
    })}
  </div>
</Layout>

<style>
  .page-title {
    font-size: 0.875rem;
    font-weight: 400;
    color: #fff;
    margin: 1rem 0 1.5rem;
    padding-left: 0.5rem;
    letter-spacing: 0.05em;
  }
  .gallery {
    max-width: 1800px;
    margin: 0 auto;
    columns: 2;
    column-gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .gallery {
      columns: 3;
    }
  }
  @media (min-width: 1024px) {
    .gallery {
      columns: 4;
    }
  }
  .gallery-item {
    display: block;
    break-inside: avoid;
    margin-bottom: 0.5rem;
  }
  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s;
  }