---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  heading?: string;
  schemaType?: string;
  breadcrumbs?: { name: string; url: string }[];
}

const { title, description = 'Photography portfolio by Cas Medlin, freelance photographer based in Iredell County, North Carolina specializing in landscapes, wildlife, portraits, events, pets, and astrophotography.', image = '/favicon.webp', canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://casmedlin.com').toString(), heading, schemaType = 'WebPage', breadcrumbs = [] } = Astro.props;
const siteName = 'Cas Medlin';
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://casmedlin.com').toString();
const ogImage = image.startsWith('http') ? image : new URL(image, Astro.site ?? 'https://casmedlin.com').toString();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/landscapes', label: 'Landscapes' },
  { href: '/architecture', label: 'Architecture' },
  { href: '/events', label: 'Events' },
  { href: '/pets', label: 'Pets' },
  { href: '/portraits', label: 'Portraits' },
  { href: '/wildlife', label: 'Wildlife' },
  { href: '/astrophotography', label: 'Astrophotography' },
  { href: '/about', label: 'About' },
];

const categories = ['landscapes', 'architecture', 'pets', 'portraits', 'wildlife', 'events', 'astrophotography'];
const currentPath = Astro.url.pathname.slice(1);
const isCategoryPage = categories.includes(currentPath);
let prevHref = '';
let nextHref = '';
if (isCategoryPage) {
  const currentIndex = categories.indexOf(currentPath);
  const prevIndex = currentIndex === 0 ? categories.length - 1 : currentIndex - 1;
  const nextIndex = currentIndex === categories.length - 1 ? 0 : currentIndex + 1;
  prevHref = '/' + categories[prevIndex];
  nextHref = '/' + categories[nextIndex];
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#151515" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/webp" href="/favicon.webp" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.ico" sizes="64x64" />
    <link rel="apple-touch-icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonical} />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Cas Medlin" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${siteName}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:creator" content="@casmedlin" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': schemaType,
          name: `${title} | ${siteName}`,
          description: description,
          url: pageUrl,
          image: ogImage,
          author: {
            '@type': 'Person',
            name: siteName,
            url: Astro.site?.toString(),
            sameAs: [
              'https://instagram.com/casmedlin',
              'https://facebook.com/casmedlin1',
              'https://youtube.com/@casmedlin'
            ]
          },
          publisher: {
            '@type': 'Person',
            name: siteName,
            image: ogImage
          }
        },
        {
          '@type': 'Person',
          name: siteName,
          jobTitle: 'Freelance Photographer',
          description: description,
          url: Astro.site?.toString(),
          image: ogImage,
          email: 'mailto:info@casmedlin.com',
          sameAs: [
            'https://instagram.com/casmedlin',
            'https://facebook.com/casmedlin1',
            'https://youtube.com/@casmedlin'
          ],
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Iredell County',
            addressRegion: 'NC',
            addressCountry: 'US'
          },
          knowsAbout: ['Landscape Photography', 'Wildlife Photography', 'Portrait Photography', 'Event Photography', 'Pet Photography', 'Astrophotography', 'Architecture Photography']
        },
        ...(breadcrumbs.length > 0 ? [{
          '@type': 'BreadcrumbList',
          itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://casmedlin.com/' },
            ...breadcrumbs.map((crumb, i) => ({
              '@type': 'ListItem',
              position: i + 2,
              name: crumb.name,
              item: crumb.url.startsWith('http') ? crumb.url : `https://casmedlin.com${crumb.url}`
            }))
          ]
        }] : [])
      ]
    })} />

    <!-- Resource Hints for performance -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preload" href="/main.js" as="script" />

    <!-- Core Web Vitals monitoring -->
    <script is:inline src="/vitals.js" defer></script>

    <!-- Google tag (gtag.js) - Deferred for performance -->
    <script type="text/javascript" client:load>
      (function() {
        var loadGTM = function() {
          if (window.gtag) return;
          var script = document.createElement('script');
          script.async = true;
          script.src = 'https://www.googletagmanager.com/gtag/js?id=G-5LHBPEXY32';
          document.head.appendChild(script);
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-5LHBPEXY32');
          window.gtag = gtag;
        };

        var interactionEvents = ['scroll', 'mousemove', 'touchstart'];
        var loadOnInteraction = function() {
          loadGTM();
          interactionEvents.forEach(function(evt) {
            document.removeEventListener(evt, loadOnInteraction);
          });
        };

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          loadGTM();
        } else {
          interactionEvents.forEach(function(evt) {
            document.addEventListener(evt, loadOnInteraction, { once: true });
          });
          setTimeout(loadGTM, 5000);
        }
      })();
    </script>

    <!-- Main script with deferred loading -->
    <script is:inline src="/main.js" defer></script>

    <!-- Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </head>
  <body class={['/about', '/about/'].includes(Astro.url.pathname) ? 'about-page' : ''}>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <nav class="nav" aria-label="Main navigation">
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/favicon.webp" alt="Cas Medlin Photography" class="logo-img" width="32" height="32" />
          <span class="logo-text">{siteName}</span>
        </a>
        <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="nav-links" id="nav-links" role="menubar">
          {navLinks.map((link) => (
            <a href={link.href} class="nav-link" role="menuitem" aria-current={Astro.url.pathname === link.href || (link.href !== '/' && Astro.url.pathname.startsWith(link.href)) ? 'page' : undefined}>{link.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <main id="main-content">
      <slot />
      {(Astro.url.pathname === '/' || isCategoryPage) && (
        <div class="nav-buttons">
          {Astro.url.pathname === '/' ? (
            <a href="/portraits" class="nav-button">See More</a>
          ) : (
            <>
              <a href={prevHref} class="nav-button">Go Back</a>
              <a href={nextHref} class="nav-button">See More</a>
            </>
          )}
        </div>
      )}
    </main>

    <footer class="footer">
      <div class="footer-content">
        <div class="work-together">
          <h3>Let's Work Together</h3>
          <p>Have a project in mind or want to book a session?</p>
          <a
            href="mailto:info@casmedlin.com"
            class="work-together-email"
            style={['/about', '/about/'].includes(Astro.url.pathname) ? 'color: #22c55e !important;' : undefined}
          >
            info@casmedlin.com
          </a>
        </div>
        <p>© {new Date().getFullYear()} Cas Medlin</p>
        <div class="social-links">
          <a href="https://instagram.com/casmedlin" target="_blank" aria-label="Instagram" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://facebook.com/casmedlin1" target="_blank" aria-label="Facebook" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="https://youtube.com/@casmedlin" target="_blank" aria-label="YouTube" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
          </a>
        </div>
        <div class="footer-links">
          <a href="https://www.biblicalencouragement.org/" target="_blank" rel="noopener">Biblical Encouragement</a>
          <a href="/sitemap">Sitemap</a>
          <a href="/privacy-policy">Privacy Policy</a>
        </div>
      </div>
    </footer>

      <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
        <button class="lightbox-close" id="lightbox-close-btn" aria-label="Close image viewer">×</button>
        <div class="lightbox-controls">
          <button class="lightbox-prev" id="lightbox-prev-btn" aria-label="Previous image">‹</button>
          <button class="lightbox-next" id="lightbox-next-btn" aria-label="Next image">›</button>
        </div>
        <img id="lightbox-img" src="" alt="" />
        <p id="lightbox-caption" class="lightbox-caption"></p>
      </div>
  </body>
</html>

 <style>
   * {
     margin: 0;
     padding: 0;
     box-sizing: border-box;
   }
   img {
     max-width: 100%;
     height: auto;
     display: block;
   }
   body {
     background-color: #151515;
     color: #fff;
     font-family: system-ui, -apple-system, sans-serif;
     min-height: 100vh;
   }
   .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    background: #22c55e;
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    z-index: 200;
    transition: top 0.2s;
  }
  .skip-link:focus {
    top: 0.5rem;
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #262626;
  }
  .nav-inner {
    max-width: 1800px;
    margin: 0 auto;
    padding: 0 1rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .logo:focus {
    outline: 2px solid #22c55e;
    outline-offset: 2px;
    border-radius: 4px;
  }
  .logo-img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }
  .logo-text {
    display: inline;
    color: #fff;
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  @media (max-width: 768px) {
    .logo-img {
      display: block;
    }
    .logo-text {
      display: inline;
    }
    .nav-links {
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      background: rgba(10, 10, 10, 0.98);
      flex-direction: column;
      padding: 1rem;
      gap: 1rem;
      display: none;
      border-bottom: 1px solid #262626;
    }
    .nav-links.active {
      display: flex;
    }
    .menu-toggle {
      display: flex;
    }
  }
  .nav-link[aria-current="page"] {
    color: #22c55e;
    font-weight: 600;
  }
  .nav-link {
    font-size: 0.875rem;
    letter-spacing: 0.025em;
    color: #d4d4d4;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link:focus {
    color: #22c55e;
    outline: none;
  }
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .menu-toggle:focus {
    outline: 2px solid #22c55e;
    outline-offset: 2px;
    border-radius: 4px;
  }
  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }
  }
  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    transition: transform 0.3s, opacity 0.3s;
  }
  main {
    padding-top: 80px;
    padding-bottom: 48px;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }

  .footer {
    border-top: 1px solid #262626;
    padding: 2rem 0;
    text-align: center;
  }
  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .work-together {
    margin-bottom: 1rem;
  }
  .work-together h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 0.5rem 0;
  }
  .work-together p {
    font-size: 0.875rem;
    color: #a3a3a3;
    margin: 0 0 0.75rem 0;
    line-height: 1.4;
  }
  .work-together-email {
    color: #a3a3a3;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .work-together-email:hover,
  .work-together-email:focus {
    color: #fff;
    outline: 2px solid #22c55e;
    outline-offset: 2px;
  }
  .footer p {
    font-size: 0.875rem;
    color: #9e9e9e;
  }
   .footer-links {
     display: flex;
     justify-content: center;
     gap: 1.5rem;
     margin-bottom: 0.5rem;
   }
  .footer-links a {
    color: #9e9e9e;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }
  .footer-links a:hover,
  .footer-links a:focus {
    color: #a3a3a3;
    outline: 2px solid #22c55e;
    outline-offset: 2px;
  }
   .social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
   }
  .social-links a {
    color: #a3a3a3;
    text-decoration: none;
    display: flex;
    align-items: center;
  }
   .social-links a:hover,
   .social-links a:focus {
    color: #22c55e;
    outline: none;
  }
  .social-links a:focus svg {
    outline: 2px solid #22c55e;
    outline-offset: 2px;
    border-radius: 4px;
  }
  .lightbox {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(4, 4, 4, 0.95);
    z-index: 100;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }
.lightbox.active {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
  }
  #lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
  }
  #lightbox-img {
    display: block;
    max-width: 90vw;
    max-height: calc(90vh - 60px);
    width: auto;
    height: auto;
  }
  .lightbox-caption {
    margin-top: 1rem;
    color: #f3f3f3;
    font-size: 0.95rem;
    line-height: 1.5;
    text-align: center;
    max-width: 90vw;
    padding: 0 1rem;
  }
  .lightbox-controls {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }
  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: #fff;
    font-size: 2.5rem;
    cursor: pointer;
    padding: 0.5rem;
    line-height: 1;
    z-index: 10;
  }
  .lightbox-close:focus,
  .lightbox-prev:focus,
  .lightbox-next:focus {
    outline: 2px solid #22c55e;
    outline-offset: 2px;
    border-radius: 4px;
  }
  .lightbox-controls {
    position: absolute;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 1rem;
    pointer-events: none;
  }
  .lightbox-prev,
  .lightbox-next {
    background: none;
    border: none;
    color: #fff;
    font-size: 3rem;
    cursor: pointer;
    padding: 1rem;
    line-height: 1;
    pointer-events: auto;
  }
  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    color: #666;
  }
  .nav-buttons {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 2rem 0;
  }
  .nav-button {
    background: #22c55e;
    color: #fff;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .nav-button:hover,
  .nav-button:focus {
    background: #16a34a;
  }
  .nav-button:focus {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .footer .work-together-email {
    color: #22c55e !important;
  }
  .footer .work-together-email:hover {
    color: #16a34a !important;
  }
  body.about-page .work-together-email {
    color: #22c55e !important;
  }
  body.about-page .work-together-email:hover {
    color: #16a34a !important;
  }
  </style>